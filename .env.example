# Supabase (https://supabase.com/dashboard) — NEXT_PUBLIC_* 는 next build 시 번들에 포함됩니다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (Playwright worker / admin scripts). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=

# LAN에서 next dev 접속 시 allowedDevOrigins에 추가(쉼표 구분). 예: 172.20.0.1
# NEXT_DEV_ALLOWED_ORIGINS=

# 자동추천 크롤링 호출 주소.
# 웹(Vercel) 배포는 비워두면 같은 도메인의 서버 프록시(/api/crawl/coupang)를 사용합니다.
# Capacitor APK 빌드(BUILD_TARGET=apk)에서는 외부 크롤링 서버를 직접 호출해야 하므로
# 아래처럼 절대 URL을 지정합니다.
# NEXT_PUBLIC_CRAWL_API_BASE_URL=http://175.125.243.56:8003/crawl/coupang
