# Supabase (https://supabase.com/dashboard) — NEXT_PUBLIC_* 는 next build 시 번들에 포함됩니다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (Playwright worker / admin scripts). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=

# LAN에서 next dev 접속 시 allowedDevOrigins에 추가(쉼표 구분). 예: 172.20.0.1
# NEXT_DEV_ALLOWED_ORIGINS=

# 자동추천 크롤링 호출 주소.
# 웹과 Capacitor 앱이 모두 아래 HTTPS 주소를 직접 호출합니다.
# NEXT_PUBLIC_CRAWL_API_BASE_URL=https://review-manager-api.jinitlab.com/crawl/coupang

# Docker Compose로 실행할 때 호스트에서 사용할 포트입니다.
APP_PORT=3000
