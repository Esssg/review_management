# Release APK signing config.
# Copy this file to `keystore.properties` and fill in real values.
# DO NOT commit the real `keystore.properties` (it is gitignored).
#
# The `.jks` file referenced by `storeFile` should also stay local
# (e.g. android/keystore/review-manager.jks). Back it up in a safe place
# outside the repository — losing it means you can never ship an update
# to the same package on any app store.

storeFile=keystore/review-manager.jks
storePassword=REPLACE_WITH_STORE_PASSWORD
keyAlias=reviewmanager
keyPassword=REPLACE_WITH_KEY_PASSWORD
