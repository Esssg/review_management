{
  "name": "review_manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "gen:types": "npx --yes supabase@latest gen types typescript --linked --schema public > src/types/database.gen.ts",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:apk:debug": "BUILD_TARGET=apk next build && cap sync android && cd android && ./gradlew assembleDebug",
    "cap:apk:release": "BUILD_TARGET=apk next build && cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@capacitor/android": "7.6.2",
    "@capacitor/app": "^7.1.2",
    "@capacitor/clipboard": "^7.0.4",
    "@capacitor/core": "7.6.2",
    "@capacitor/ios": "7.6.2",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/cli": "7.6.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
